{
  "opencollection": "1.0.0",
  "info": {
    "name": "Raygun Pages API",
    "version": "3.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "pages",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Pages for an Application",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.raygun.com/v3/applications/:application-identifier/pages",
            "params": [
              {
                "name": "count",
                "value": "",
                "type": "query",
                "description": "Limits the number of items in the response"
              },
              {
                "name": "offset",
                "value": "",
                "type": "query",
                "description": "Number of items to skip before returning results"
              },
              {
                "name": "orderby",
                "value": "",
                "type": "query",
                "description": "Order items by property values"
              }
            ],
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
          },
          "docs": "Returns a list of pages for the specified application"
        },
        {
          "info": {
            "name": "Get Page by Identifier",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.raygun.com/v3/applications/:application-identifier/pages/:page-identifier",
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
          },
          "docs": "Returns a page by identifier"
        }
      ]
    }
  ],
  "bundled": true
}