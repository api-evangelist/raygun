{
  "opencollection": "1.0.0",
  "info": {
    "name": "Raygun Teams API",
    "version": "3.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "teams",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Teams",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.raygun.com/v3/teams",
            "params": [
              {
                "name": "count",
                "value": "",
                "type": "query",
                "description": "Limits the number of items in the response"
              },
              {
                "name": "offset",
                "value": "",
                "type": "query",
                "description": "Number of items to skip before returning results"
              },
              {
                "name": "orderby",
                "value": "",
                "type": "query",
                "description": "Order items by property values"
              }
            ],
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
          },
          "docs": "Returns the teams for a plan"
        },
        {
          "info": {
            "name": "Get Team by Identifier",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.raygun.com/v3/teams/:team-identifier",
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
          },
          "docs": "Returns a team with the given identifier"
        }
      ]
    }
  ],
  "bundled": true
}